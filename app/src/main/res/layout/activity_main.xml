<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good morning 🌟"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tuesday, June 17"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Today's Mood Card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TODAY'S MOOD"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="#9CA3AF"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/card_today"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#F3F4F6"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_today_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝"
                    android:textSize="42sp"
                    android:layout_marginEnd="16dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_today_mood"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Not logged yet"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1F2937" />

                    <TextView
                        android:id="@+id/tv_today_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap Log Mood to get started"
                        android:textSize="13sp"
                        android:textColor="#6B7280"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Weekly Overview -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THIS WEEK"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="#9CA3AF"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:id="@+id/ll_week_dots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3F4F6"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tv_week_avg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No data yet"
                    android:textSize="14sp"
                    android:textColor="#374151"
                    android:gravity="center"
                    android:layout_gravity="center" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Action Buttons -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUICK ACTIONS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textColor="#9CA3AF"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_log_mood"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📝  Log Today's Mood"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6366F1"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_history"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="📊  History"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#6366F1"
                android:backgroundTint="#EEF2FF"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_recommend"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="💡  Tips"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#059669"
                android:backgroundTint="#ECFDF5"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_about_developer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_about_developer"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#4B5563"
            android:backgroundTint="#F3F4F6" />

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>
