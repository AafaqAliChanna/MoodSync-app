<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MoodSync" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="buttonStyle">@style/Widget.MoodSync.Button</item>
    </style>

    <style name="Widget.MoodSync.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:stateListAnimator">@null</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>
